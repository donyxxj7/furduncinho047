{
  "version": 2,
  "rewrites": [
    { "source": "/api/trpc/:path*", "destination": "/api/index.js" },
    { "source": "/api/:path*", "destination": "/api/index.js" },
    { "source": "/((?!api/).*)", "destination": "/dist/index.html" }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": "{server/**,dist/**}"
    }
  }
}
